# Copy to terraform.tfvars and fill with real values. terraform.tfvars is
# gitignored. The secrets and the ssh key have no default and are required.

ssh_public_key      = "ssh-ed25519 AAAA... your-key"
admin_cidr          = "1.2.3.4/32"   # your IP in /32; never 0.0.0.0/0

mongo_root_password = "change-me-to-a-real-secret"
redis_password      = "change-me-to-a-real-secret"
jwt_secret          = "change-me-to-a-long-random-string-min-32-chars"
admin_password      = "change-me-min-8-chars"

# Optional overrides (defaults shown):
# aws_region       = "us-east-1"
# project_name     = "pokedex"
# instance_type    = "t3.micro"   # Free Tier eligible
# api_image        = "ghcr.io/lucasidev/pokedex-api:latest"
# mongo_root_user  = "pokedex"
# admin_email      = "admin@pokedex.local"
